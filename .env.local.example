# Enable the AI Socratic tutor.
# Get a key at https://vercel.com/ai-gateway (works with any provider via "provider/model" strings).
# Copy this file to .env.local and fill in your key.
AI_GATEWAY_API_KEY=

# Optional: override the model the tutor uses (default: anthropic/claude-haiku-4-5).
# TUTOR_MODEL=anthropic/claude-haiku-4-5
