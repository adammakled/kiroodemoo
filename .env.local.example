# Enable the AI Socratic tutor.
# Copy this file to .env.local and add your key.

# Option A — direct Anthropic key (https://console.anthropic.com/):
ANTHROPIC_API_KEY=

# Optional: override the tutor model (default: claude-haiku-4-5).
# TUTOR_MODEL=claude-haiku-4-5

# Option B — route through the Vercel AI Gateway instead (provider-swappable
# "provider/model" strings). If you use this, set the model in the route to e.g.
# "anthropic/claude-haiku-4-5" and provide:
# AI_GATEWAY_API_KEY=
